{
  "builds": [
    { "src": "api/convert.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/convert", "dest": "/api/convert.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "functions": {
    "api/convert.js": {
      "maxDuration": 30
    }
  }
}
